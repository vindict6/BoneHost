# ---- BoneHost panel secrets (copy to .env on the server, never commit .env) ----

# Long random string; sign-in cookies are signed with this. `openssl rand -hex 48`
JWT_SECRET=change-me

# Seed admin account (created on first boot only; change the password after first login)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-now

# Payments: the default provider is "manual" (Venmo / Cash App) and needs NO
# secrets here — just set your handle(s) in config.json under billing.manual.
#
# OPTIONAL alternative: self-hosted BTCPay Server (fully automated settlement).
# Only fill these in if you set billing.provider to "btcpay" in config.json.
# BTCPAY_URL=https://btcpay.example.com
# BTCPAY_API_KEY=
# BTCPAY_STORE_ID=
# BTCPAY_WEBHOOK_SECRET=

# Steam Web API key (https://steamcommunity.com/dev/apikey) - used only to
# resolve vanity profile links to SteamID64 when subscribers add admins.
STEAM_API_KEY=

# MariaDB root password on the game node (the agent uses it to provision
# per-server SimpleAdmin DBs). Set the SAME value in both .env files.
MARIADB_ROOT_PASSWORD=change-me

# ---- node agents (panel side) ----
# One token per node in config.json, named NODE_TOKEN_<ID> (uppercased).
# Generate with `openssl rand -hex 32`.
NODE_TOKEN_RYZEN=change-me-32-plus-chars

# ---- game node side (only needed in the node's /opt/bonehost/.env) ----
# Must match the panel's NODE_TOKEN_<ID> for this machine.
AGENT_TOKEN=change-me-32-plus-chars

# The node's Tailscale IPv4 (`tailscale ip -4`). The agent binds to this address
# exclusively, so it is unreachable from the public internet by construction.
TAILSCALE_IP=100.x.y.z

# ---- head unit side (optional) ----
# Set to 0 if the panel is published through a Cloudflare Tunnel (cloudflared)
# instead of an open 443 — the firewall script then closes 80/443 too.
# PANEL_PUBLIC_HTTP=0

# Optional: comma-separated CIDRs/IPs allowed to hit /api/admin/* (extra armor for you)
# ADMIN_IP_ALLOWLIST=203.0.113.5,10.0.0.0/8
