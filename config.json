{
  "panel": {
    "name": "BoneHost",
    "url": "https://bonehost.org",
    "port": 8080,
    "data_root": "/srv/bonehost-panel",
    "comment": "The panel is the head unit: web UI, API, SQLite, billing, schedulers. It holds no game files and needs no docker.sock \u2014 it drives nodes over their agent APIs."
  },
  "cs2": {
    "image": "bonehost/cs2:latest",
    "update_on_start": true,
    "default_map": "de_dust2",
    "default_game_mode": {
      "game_type": 0,
      "game_mode": 1,
      "comment": "0/1 = competitive"
    },
    "default_cfg": {
      "hostname": "BoneHost | Competitive",
      "sv_lan": "0",
      "sv_cheats": "0",
      "mp_autoteambalance": "0",
      "mp_limitteams": "0",
      "mp_overtime_enable": "1",
      "mp_maxrounds": "24",
      "mp_freezetime": "15",
      "mp_match_end_restart": "1",
      "sv_deadtalk": "1",
      "sv_full_alltalk": "0",
      "sv_hibernate_when_empty": "1",
      "sv_hibernate_postgame_delay": "300",
      "tv_enable": "1",
      "tv_delay": "105"
    }
  },
  "addons": {
    "metamod": {
      "branch": "2.0",
      "latest_index": "https://mms.alliedmods.net/mmsdrop/2.0/mmsource-latest-linux"
    },
    "counterstrikesharp": {
      "repo": "roflmuffin/CounterStrikeSharp",
      "asset_match": "with-runtime-linux"
    },
    "default_plugins": [
      {
        "name": "FakeRcon",
        "repo": "kus/cs2-fakercon",
        "asset_match": ".zip",
        "comment": "Restores RCON on CS2. Verify the repo slug once before first deploy; it is fetched from the GitHub Releases API at install time."
      },
      {
        "name": "CS2-SimpleAdmin",
        "repo": "daffyyyy/CS2-SimpleAdmin",
        "asset_match": ".zip",
        "needs_database": true
      }
    ]
  },
  "billing": {
    "currency": "USD",
    "price_per_slot_cents_monthly": 2000,
    "yearly_months_charged": 10,
    "grace_days": 3,
    "renewal_notice_days": 7,
    "provider": "manual",
    "manual": {
      "venmo_username": "your-venmo-username",
      "cashapp_cashtag": "YourCashtag",
      "note": "Put the invoice code in the payment note so payments match up fast."
    }
  },
  "updates": {
    "scheduler_timezone": "America/Denver"
  },
  "nodes": [
    {
      "id": "ryzen",
      "name": "Ryzen 7950X",
      "comment": "The head unit (panel on the mini PC) drives this box through the agent. To scale, copy this block, change id/agent_url/public_host, set NODE_TOKEN_<ID> in the panel .env, and deploy the agent stack on the new machine.",
      "agent_url": "http://ryzen.your-tailnet.ts.net:9090",
      "public_host": "play.bonehost.org",
      "game_port_range": [
        27015,
        27999
      ],
      "cpu": {
        "comment": "16c/32t: logical thread N and N+16 are SMT siblings. Only pool threads are ever given to game containers; the rest stay reserved for the OS/agent/MariaDB/SFTP.",
        "pool": [
          4,
          20,
          5,
          21,
          6,
          22,
          7,
          23,
          8,
          24,
          9,
          25,
          10,
          26,
          11,
          27,
          12,
          28,
          13,
          29,
          14,
          30,
          15,
          31
        ],
        "smt_sibling_offset": 16,
        "threads_per_server": 4,
        "pin_sibling_pairs": true
      },
      "memory": {
        "total_mb": 65536,
        "host_reserved_mb": 12288,
        "per_server_mb": 8192,
        "swap": "disabled (MemorySwap pinned to Memory limit)"
      },
      "agent_url_comment": "The node's Tailscale MagicDNS name (or 100.x.y.z IP). The agent only listens on the tailnet.",
      "ssh_port_range": [
        28000,
        29000
      ],
      "ports_comment": "Both ranges sit inside 27015-29000, the only public ports UFW opens on a node (scripts/firewall-node.sh)."
    }
  ]
}